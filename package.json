{
  "name": "compliance-app",
  "private": true,
  "packageManager": "bun@1.3.12",
  "workspaces": {
    "packages": [
      "api",
      "compliance-engine",
      "web"
    ],
    "catalog": {
      "@types/bun": "latest",
      "@types/node": "^25.6.0",
      "typescript": "^5.9.3"
    }
  },
  "scripts": {
    "dev": "bun run api:dev",
    "api:dev": "bun run --cwd ./api dev",
    "api:start": "bun run --cwd ./api start",
    "api:typecheck": "bun run --cwd ./api typecheck",
    "api:test": "bun run --cwd ./api test",
    "engine:test": "bun run --cwd ./compliance-engine test",
    "engine:test-ui": "bun run --cwd ./compliance-engine test:ui",
    "engine:typecheck": "bun run --cwd ./compliance-engine typecheck",
    "web:dev": "bun run --cwd ./web dev",
    "web:build": "bun run --cwd ./web build",
    "web:typecheck": "bun run --cwd ./web typecheck",
    "web:test": "bun run --cwd ./web test",
    "local:generate-coe-keys": "bun run scripts/generate-coe-keypair.ts",
    "local:render-worker-config": "bun run scripts/render-local-worker-config.ts",
    "local:sign-worker-config": "bun run scripts/sign-worker-config.ts",
    "local:e2e": "bun run scripts/local-e2e.ts",
    "test": "bun run api:test && bun run engine:test && bun run web:test",
    "typecheck": "bun run api:typecheck && bun run engine:typecheck && bun run web:typecheck",
    "check": "bun run typecheck && bun run api:test && bun run engine:test && bun run web:build"
  },
  "devDependencies": {
    "@types/node": "^25.6.0"
  },
  "dependencies": {
    "postgres": "^3.4.9"
  }
}
